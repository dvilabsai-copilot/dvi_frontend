# Safe variable names only. Store real values in a local ignored .env.e2e file or CI secrets.
E2E_FRONTEND_BASE_URL=http://localhost:8080
E2E_API_BASE_URL=http://localhost:4006/api/v1
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
E2E_AGENT_EMAIL=
E2E_AGENT_PASSWORD=
E2E_DATABASE_NAME=dvi_e2e
E2E_RUN_ID=PW_E2E_local_001
E2E_ALLOW_WRITES=false
E2E_EXTERNAL_MOCK_MODE=mock

